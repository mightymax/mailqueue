ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
APP_REPLICAS=2
DATABASE_URL=postgres://user:password@postgres-host:5432/mailqueue
DATABASE_SSL=false
ENCRYPTION_KEY=replace-with-base64-32-byte-key
DEFAULT_FROM_EMAIL=no-reply@example.com
PUBLIC_BASE_URL=https://mailqueue.ldmax.nl
SMTP_CONNECTION_TIMEOUT_MS=4000
SMTP_GREETING_TIMEOUT_MS=4000
SMTP_SOCKET_TIMEOUT_MS=8000
WORKER_BATCH_SIZE=20
WORKER_POLL_INTERVAL_MS=5000
